{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "dist": "electron-builder build --win --macos"
  },
  "build": {
    "appId": "com.alshifa.mlms",
    "productName": "Al-Shifa MLMS",
    "files": [
      "**/*",
      "mlms.sqlite",
      "sql-wasm.wasm"
    ],
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.medical"
    },
    "directories": {
      "output": "dist-desktop"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-is-dev": "^3.0.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "sql.js": "^1.14.1",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
